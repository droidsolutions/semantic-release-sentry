{
  "name": "@droidsolutions-oss/semantic-release-sentry",
  "version": "1.0.88",
  "description": "Semantic release plugin to create Sentry releases",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "test": "jest"
  },
  "keywords": [
    "Sentry",
    "semantic-release",
    "semantic",
    "release",
    "plugin"
  ],
  "author": "Stefan Ißmer <stefan.issmer@droidsolutions.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/droidsolutions/semantic-release-sentry.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=15.14.0"
  },
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "@sentry/cli": "^2.6.0",
    "execa": "^5.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@swc-node/jest": "1.9.1",
    "@types/aggregate-error": "1.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.2",
    "@types/semantic-release": "21.1.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-circus": "30.4.2",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "semantic-release": "25.0.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0"
  },
  "lint-staged": {
    "*.{js,mjs,ts,mts,json,md,yml}": "prettier --write",
    "*.{js,mjs,ts,mts}": "eslint"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -e $HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "beta",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "lib/**/*.mts"
    ],
    "coverageReporters": [
      "lcov",
      "html",
      "text"
    ],
    "moduleFileExtensions": [
      "mts",
      "mjs",
      "js",
      "ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.mjs$": "$1"
    },
    "transform": {
      "^.+\\.m?(t|j)sx?$": [
        "<rootDir>/swc-jest-transformer.cjs",
        {
          "dynamicImport": true,
          "module": "commonjs",
          "swc": {
            "jsc": {
              "externalHelpers": false
            }
          }
        }
      ]
    },
    "testEnvironment": "node",
    "testMatch": null,
    "testRegex": "test/.*\\.test\\.mts$",
    "testRunner": "jest-circus/runner"
  }
}
