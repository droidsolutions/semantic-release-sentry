{
  "name": "@droidsolutions-oss/semantic-release-sentry",
  "version": "2.0.0-beta.1",
  "description": "Semantic release plugin to create Sentry releases",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "Sentry",
    "semantic-release",
    "semantic",
    "release",
    "plugin"
  ],
  "author": "Stefan Ißmer <stefan.issmer@droidsolutions.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/droidsolutions/semantic-release-sentry.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^18.19.0 || >=20.5.0"
  },
  "dependencies": {
    "@semantic-release/error": "^4.0.0",
    "@sentry/cli": "^3.5.0",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/aggregate-error": "1.0.1",
    "@types/node": "25.9.2",
    "@types/semantic-release": "21.1.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "semantic-release": "25.0.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,mjs,ts,mts,json,md,yml}": "prettier --write",
    "*.{js,mjs,ts,mts}": "eslint"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -e $HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "beta",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ]
  }
}
